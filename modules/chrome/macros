{
  "macros": [
    {
      "id": "androidx.ChromeFrameAnalysis",
      "name": "Chrome Frame Analysis",
      "run": [
        {
          "id": "dev.perfetto.RunQueryAndShowTab",
          "args": [
            "SELECT * FROM chrome_frame_times"
          ]
        }
      ]
    },
    {
      "id": "androidx.ShowLongTasks",
      "name": "Show Long Tasks",
      "run": [
        {
          "id": "dev.perfetto.RunQueryAndShowTab",
          "args": [
            "SELECT * FROM slice WHERE dur > 50000000 AND name LIKE '%Task%'"
          ]
        }
      ]
    }
  ]
}
